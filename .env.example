# Secret used to sign and verify JWTs (use a long random string)
JWT_SECRET=your-jwt-secret-here

# Password for the PostgreSQL user-service database
DB_PASSWORD=your-db-password-here

# LocalStack Pro auth token — required for Lambda support
# Get yours at https://app.localstack.cloud/
LOCALSTACK_AUTH_TOKEN=ls-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
